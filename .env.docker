# ========================================
# FASE 2: VARIÁVEIS DE AMBIENTE DOCKER
# ========================================
# Arquivo para desenvolvimento local com Docker
# Para produção, use variáveis de ambiente ou secrets do orquestrador

# ========================================
# BANCO DE DADOS
# ========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_docker_dev_senha_segura_123
DB_NAME=agentefecha

# ========================================
# APLICAÇÃO
# ========================================
NODE_ENV=production
LOG_LEVEL=info
DEBUG=false

# ========================================
# INTELIGÊNCIA ARTIFICIAL
# ========================================
# Gemini (Google) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# xAI (X) - https://console.x.ai/
XAI_API_KEY=

# Qual IA usar: 'gemini' (padrão) ou 'xai'
IA_PROVIDER=gemini

# ========================================
# WHATSAPP
# ========================================
# Quantidade de números (máx 10)
WHATSAPP_NUMEROS=1

# Número 1
WHATSAPP_1_NOME=Amanda
WHATSAPP_1_ESTILO=acolhedora, direta e espontânea

# ========================================
# PROSPECÇÃO
# ========================================
# Caminho da lista CSV
PROSPECCAO_CSV=./listas/lista-atual.csv

# Ativar envios (false = apenas prévia/teste)
PROSPECCAO_ATIVA=false

# Intervalo entre envios em ms (mín 180000 = 3 min)
PROSPECCAO_INTERVALO_MS=180000

# ========================================
# FRONTEND & SEGURANÇA
# ========================================
FRONTEND_PORTA=3099

# Chave API para proteger o painel
# GERE UMA NOVA: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAINEL_API_KEY=dev_key_change_in_production_12345678901234567890

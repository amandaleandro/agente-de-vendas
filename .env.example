# 🤖 Fezinha Bot - Configuração de Ambiente
# Copie este arquivo para backend/config/.env e preencha com seus dados

# ===============================
# 🧠 IA - GEMINI (Recomendado)
# ===============================
GEMINI_API_KEY=AIzaSy... # https://aistudio.google.com/app/apikey

# ===============================
# 🧠 IA - xAI (Alternativa)
# ===============================
XAI_API_KEY=  # https://console.x.ai/

# ===============================
# 🤖 IA Provider
# ===============================
IA_PROVIDER=gemini  # ou "xai"

# ===============================
# 💬 WhatsApp
# ===============================
WHATSAPP_NUMEROS=1  # Quantidade de números
WHATSAPP_1_NOME=Fezinha  # Nome do bot
WHATSAPP_1_ESTILO=profissional  # profissional|casual|técnico

# ===============================
# 🎯 Prospecção
# ===============================
PROSPECCAO_ATIVA=false  # true para ativar
PROSPECCAO_INTERVALO=3000  # ms entre mensagens
PROSPECCAO_POR_LOTE=5  # contatos por lote

# ===============================
# 📊 Banco de Dados (Opcional)
# ===============================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=fezinha
DB_POOL_SIZE=10

# ===============================
# 🔧 Servidor
# ===============================
PORT=3099
NODE_ENV=production
LOG_LEVEL=info

# ===============================
# 💾 Backup
# ===============================
BACKUP_INTERVALO=21600000  # 6 horas em ms
BACKUP_DIRETORIO=./backups

# ===============================
# ⚙️  Limites
# ===============================
MAX_HISTORICO_POR_CONTATO=2
MAX_MENSAGENS_ENVIADAS=300
MAX_TENTATIVAS_RECONEXAO=5

# ===============================
# 🔐 Segurança
# ===============================
RATE_LIMIT_POR_IP=100  # requisições por hora
RATE_LIMIT_JANELA=3600000  # 1 hora em ms

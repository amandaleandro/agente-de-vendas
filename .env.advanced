# ========================================
# CONFIGURAÇÕES AVANÇADAS (OPCIONAL)
# ========================================
# Copie este arquivo para .env para habilitar recursos avançados

# ========================================
# DEBUG & LOGGING
# ========================================
# Ativar logging detalhado
DEBUG=false

# Nível de log: error, warn, info, debug
LOG_LEVEL=info

# Retenção de logs em dias
LOG_RETENTION_DAYS=7

# ========================================
# PERFORMANCE & CACHE
# ========================================
# TTL do cache em segundos
CACHE_TTL=300

# Tamanho máximo do cache em MB
CACHE_MAX_SIZE=50

# ========================================
# RATE LIMITING CUSTOMIZADO
# ========================================
# Limite global de requisições por minuto
RATELIMIT_GLOBAL=100

# Limite por endpoint em requisições por minuto
RATELIMIT_API_LISTA=10
RATELIMIT_API_INICIAR=5
RATELIMIT_API_TANK_GERAR=3
RATELIMIT_API_TANK_CARREGAR=5
RATELIMIT_DEFAULT=30

# ========================================
# BACKUP & RECOVERY
# ========================================
# Intervalo de backup automático em horas
BACKUP_INTERVAL_HOURS=6

# Retenção de backups em dias
BACKUP_RETENTION_DAYS=30

# ========================================
# HEALTH CHECK
# ========================================
# Intervalo de health check em segundos
HEALTHCHECK_INTERVAL=60

# Alertar se memória > X% (0-100)
MEMORY_ALERT_THRESHOLD=80

# Alertar se disco > X% (0-100)
DISK_ALERT_THRESHOLD=85

# ========================================
# DATABASE
# ========================================
# Pool de conexões
DB_POOL_MIN=2
DB_POOL_MAX=10

# Timeout de conexão em ms
DB_TIMEOUT=3000

# ========================================
# WHATSAPP ADVANCED
# ========================================
# Intervalo de reconexão base em ms
RECONNECT_BASE_DELAY=1000

# Máximo de tentativas de reconexão
MAX_RECONNECT_ATTEMPTS=5

# Pausa entre reconexões após falha (minutos)
RECONNECT_PAUSE_MINUTES=5

# ========================================
# PROSPECÇÃO ADVANCED
# ========================================
# Tempo máximo de execução de prospecção em horas
PROSPECCAO_MAX_DURATION_HOURS=4

# Intervalo mínimo entre mensagens em ms
PROSPECCAO_MIN_INTERVAL=180000

# ========================================
# TANK (MESSAGE QUEUE)
# ========================================
# Intervalo de processamento da fila em ms
TANK_PROCESS_INTERVAL=6000

# Atraso entre mensagens para mesmo contato em ms
TANK_MESSAGE_DELAY=60000

# Rotação de fila em MB
TANK_ROTATION_SIZE_MB=100

# ========================================
# WARMUP
# ========================================
# Dias de aquecimento antes de limite máximo
WARMUP_DAYS=7

# Rotação de stats em MB
WARMUP_ROTATION_SIZE_MB=50

# ========================================
# SECURITY
# ========================================
# Permitir CORS (para desenvolvimento)
CORS_ENABLED=false

# Origins permitidas (separado por vírgula)
CORS_ORIGINS=http://localhost:3099

# Habilitar HTTPS (requer certificado)
HTTPS_ENABLED=false

# Caminho do certificado SSL
SSL_CERT_PATH=/caminho/do/certificado.crt
SSL_KEY_PATH=/caminho/da/chave.key

# ========================================
# MONITORAMENTO EXTERNO
# ========================================
# Enviar métricas para Prometheus
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Webhook para alertas
ALERT_WEBHOOK_URL=https://seu-webhook.com/alerta

# Email para alertas críticos
ALERT_EMAIL=seu-email@exemplo.com

# ========================================
# DEVELOPMENT
# ========================================
# Modo desenvolvimento (mais verbose)
NODE_ENV=production

# Desabilitar autenticação em dev
DEV_NO_AUTH=false

# ========================================
# NOTAS
# ========================================
# 1. Este arquivo é opcional - use valores padrão se não configurar
# 2. Valores aqui substituem os padrões do código
# 3. Será ignorado se não existir
# 4. Mantenha seguro - não commite com valores reais
